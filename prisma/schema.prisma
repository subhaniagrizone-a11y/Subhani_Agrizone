generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  FARMER
  DEALER
  ADMIN
  MANAGER
  SUPPORT
}

enum ProductStatus {
  DRAFT
  ACTIVE
  OUT_OF_STOCK
  ARCHIVED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  PAID
  PARTIAL
  FAILED
  REFUNDED
}

enum InquiryType {
  CONTACT
  DEALER_REGISTRATION
  FARMER_REGISTRATION
  BULK_INQUIRY
  QUOTATION_REQUEST
  NEWSLETTER
  SUPPORT_TICKET
  PRODUCT_INQUIRY
}

model User {
  id              String            @id @default(cuid()) @map("_id")
  name            String?
  email           String?           @unique
  emailVerified   DateTime?
  phone           String?           @unique
  phoneVerified   DateTime?
  passwordHash    String?
  image           String?
  role            Role              @default(CUSTOMER)
  rewardPoints    Int               @default(0)
  accounts        Account[]
  sessions        Session[]
  addresses       Address[]
  orders          Order[]
  reviews         Review[]
  wishlist        WishlistItem[]
  compareItems    CompareItem[]
  notifications   Notification[]
  rewardLedger    RewardLedger[]
  referralsSent   Referral[]        @relation("Referrer")
  referralsJoined Referral[]        @relation("Referred")
  preferences     UserPreferences?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model UserPreferences {
  id              String    @id @default(cuid()) @map("_id")
  userId          String    @unique
  theme           String    @default("light")
  colorScheme     String    @default("eco-green")
  primaryColor    String    @default("#10b981")
  accentColor     String    @default("#34d399")
  secondaryColor  String    @default("#6b7280")
  fontFamily      String    @default("system")
  language        String    @default("en")
  currency        String    @default("PKR")
  notifications   Boolean   @default(true)
  emailMarketing  Boolean   @default(true)
  smsNotifications Boolean  @default(false)
  whatsappNotifications Boolean @default(true)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid()) @map("_id")
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid()) @map("_id")
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id        String   @id @default(cuid()) @map("_id")
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id                  String     @id @default(cuid()) @map("_id")
  name                String
  slug                String     @unique
  description         String?
  imageUrl            String?
  icon                String?
  featured            Boolean    @default(false)
  sortOrder           Int        @default(0)
  parentId            String?
  parent              Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children            Category[] @relation("CategoryTree")
  products            Product[]  @relation("ProductCategory")
  subcategoryProducts Product[]  @relation("ProductSubcategory")
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
}

model Brand {
  id          String    @id @default(cuid()) @map("_id")
  name        String
  slug        String    @unique
  logoUrl     String?
  description String?
  website     String?
  featured    Boolean   @default(false)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id                 String            @id @default(cuid()) @map("_id")
  title              String
  slug               String            @unique
  sku                String            @unique
  barcode            String?
  status             ProductStatus     @default(DRAFT)
  brandId            String?
  brand              Brand?            @relation(fields: [brandId], references: [id])
  categoryId         String
  category           Category          @relation("ProductCategory", fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subcategoryId      String?
  subcategory        Category?         @relation("ProductSubcategory", fields: [subcategoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  price              Float             
  salePrice          Float?            
  wholesalePrice     Float?            
  dealerPrice        Float?            
  farmerPrice        Float?            
  stock              Int               @default(0)
  lowStockThreshold  Int               @default(10)
  rating             Float             @default(0)
  reviewCount        Int               @default(0)
  shortDescription   String?
  description        String            
  specifications     Json              @default("{}")
  usage              String?           
  dosage             String?           
  benefits           String[]          @default([])
  safetyInstructions String[]          @default([])
  downloads          Json              @default("[]")
  videoUrl           String?
  metaTitle          String?
  metaDescription    String?
  canonicalUrl       String?
  images             ProductImage[]
  variants           ProductVariant[]
  reviews            Review[]
  wishlistItems      WishlistItem[]
  compareItems       CompareItem[]
  inventoryLogs      InventoryLog[]
  orderItems         OrderItem[]
  relatedProducts    ProductRelation[] @relation("RelatedFrom")
  relatedTo          ProductRelation[] @relation("RelatedTo")
  recentlyViewed     RecentlyViewed[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([categoryId])
  @@index([brandId])
  @@index([status])
}

model ProductImage {
  id        String   @id @default(cuid()) @map("_id")
  productId String
  url       String
  alt       String
  sortOrder Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model ProductVariant {
  id        String   @id @default(cuid()) @map("_id")
  productId String
  name      String
  value     String
  sku       String?  @unique
  price     Float?
  stock     Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductRelation {
  id        String   @id @default(cuid()) @map("_id")
  productId String
  relatedId String
  product   Product @relation("RelatedFrom", fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  related   Product @relation("RelatedTo", fields: [relatedId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([productId, relatedId])
}

model Review {
  id        String   @id @default(cuid()) @map("_id")
  productId String
  userId    String
  rating    Int
  title     String?
  body      String
  approved  Boolean  @default(false)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WishlistItem {
  id        String   @id @default(cuid()) @map("_id")
  userId    String
  productId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model CompareItem {
  id        String   @id @default(cuid()) @map("_id")
  userId    String
  productId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model RecentlyViewed {
  id        String   @id @default(cuid()) @map("_id")
  sessionId String
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([sessionId, productId])
}

model Address {
  id         String   @id @default(cuid()) @map("_id")
  userId     String
  label      String
  fullName   String
  phone      String
  line1      String
  line2      String?
  city       String
  province   String
  postalCode String?
  country    String   @default("Pakistan")
  isDefault  Boolean  @default(false)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders     Order[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Order {
  id              String        @id @default(cuid()) @map("_id")
  orderNumber     String        @unique
  checkoutKey     String?       @unique
  userId          String
  addressId       String?
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(UNPAID)
  paymentMethod   String
  paymentProvider String?
  paymentReference String?
  trackingNumber  String?
  shippingZone    String?
  deliveryMethod  String?
  shippingCharge  Float         @default(0)
  subtotal        Float         
  discountTotal   Float         @default(0)
  taxTotal        Float         @default(0)
  grandTotal      Float         
  currency        String        @default("PKR")
  estimatedDelivery String?
  couponCode      String?
  notes           String?
  shippingAddress Json?
  billingAddress  Json?
  checkoutSnapshot Json?
  user            User          @relation(fields: [userId], references: [id])
  address         Address?      @relation(fields: [addressId], references: [id])
  items           OrderItem[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model OrderItem {
  id          String   @id @default(cuid()) @map("_id")
  orderId     String
  productId   String
  variantId   String?
  productName String
  sku         String
  quantity    Int
  price       Float
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt   DateTime @default(now())
}

model Coupon {
  id              String   @id @default(cuid()) @map("_id")
  code            String   @unique
  description     String?
  discountType    String
  discountValue   Float
  minOrderValue   Float?
  startsAt        DateTime
  endsAt          DateTime
  usageLimit      Int?
  usedCount       Int      @default(0)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model RewardLedger {
  id        String   @id @default(cuid()) @map("_id")
  userId    String
  points    Int
  reason    String
  orderId   String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Referral {
  id         String   @id @default(cuid()) @map("_id")
  code       String   @unique
  referrerId String
  referredId String?
  status     String   @default("PENDING")
  referrer   User     @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred   User?    @relation("Referred", fields: [referredId], references: [id])
  createdAt  DateTime @default(now())
}

model ShippingZone {
  id                 String   @id @default(cuid()) @map("_id")
  name               String
  cities             String[] @default([])
  baseCharge         Float
  freeShippingAbove  Float?
  estimatedDays      String
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Supplier {
  id             String          @id @default(cuid()) @map("_id")
  name           String
  contactPerson  String?
  phone          String?
  email          String?
  address        String?
  purchaseOrders PurchaseOrder[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model PurchaseOrder {
  id          String    @id @default(cuid()) @map("_id")
  supplierId  String
  reference   String    @unique
  status      String    @default("DRAFT")
  total        Float     @default(0)
  supplier    Supplier  @relation(fields: [supplierId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model InventoryLog {
  id        String   @id @default(cuid()) @map("_id")
  productId String
  quantity  Int
  type      String
  note      String?
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Notification {
  id        String    @id @default(cuid()) @map("_id")
  userId    String?
  title     String
  body      String
  channel   String
  readAt    DateTime?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
}

model SiteSetting {
  id        String   @id @default(cuid()) @map("_id")
  key       String   @unique
  value     Json
  group     String   @default("general")
  updatedAt DateTime @updatedAt
}

model HomepageSection {
  id        String   @id @default(cuid()) @map("_id")
  key       String   @unique
  title     String
  content   Json
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id              String   @id @default(cuid()) @map("_id")
  title           String
  slug            String   @unique
  excerpt         String
  content         String
  coverImage      String?
  authorName      String
  published       Boolean  @default(false)
  publishedAt     DateTime?
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid()) @map("_id")
  name      String
  role      String?
  quote     String
  rating    Int      @default(5)
  imageUrl  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Faq {
  id        String   @id @default(cuid()) @map("_id")
  question  String
  answer    String
  category  String?
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Inquiry {
  id        String      @id @default(cuid()) @map("_id")
  type      InquiryType @default(CONTACT)
  name      String
  email     String?
  phone     String?
  company   String?
  subject   String?
  message   String
  productId String?
  status    String      @default("NEW")
  metadata  Json        @default("{}")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model SeoSetting {
  id              String   @id @default(cuid()) @map("_id")
  entityType      String
  entityId        String?
  title           String
  description     String
  keywords        String[] @default([])
  canonicalUrl    String?
  openGraphImage  String?
  noIndex         Boolean  @default(false)
  structuredData  Json     @default("{}")
  updatedAt       DateTime @updatedAt

  @@unique([entityType, entityId])
}
