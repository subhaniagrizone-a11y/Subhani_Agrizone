{
  "name": "subhni-agrizone",
  "version": "1.0.0",
  "private": true,
  "description": "Premium agriculture ecommerce and CMS platform for Subhni Agrizone.",
  "engines": {
    "node": ">=20.11.1 <21",
    "npm": ">=10 <11"
  },
  "packageManager": "npm@10.2.4",
  "scripts": {
    "dev": "%npm_node_execpath% --max-old-space-size=4096 ./node_modules/next/dist/bin/next dev --webpack",
    "dev:lowmem": "%npm_node_execpath% --max-old-space-size=3072 ./node_modules/next/dist/bin/next dev --webpack",
    "dev:turbo": "%npm_node_execpath% --max-old-space-size=4096 ./node_modules/next/dist/bin/next dev --turbo",
    "build": "%npm_node_execpath% --max-old-space-size=6144 ./node_modules/next/dist/bin/next build",
    "start": "%npm_node_execpath% ./node_modules/next/dist/bin/next start",
    "lint": "%npm_node_execpath% ./node_modules/eslint/bin/eslint.js . --max-warnings=0",
    "typecheck": "%npm_node_execpath% ./node_modules/typescript/bin/tsc --noEmit",
    "prisma:generate": "%npm_node_execpath% ./node_modules/prisma/build/index.js generate",
    "prisma:migrate": "%npm_node_execpath% ./node_modules/prisma/build/index.js migrate dev",
    "prisma:studio": "%npm_node_execpath% ./node_modules/prisma/build/index.js studio",
    "seed": "%npm_node_execpath% ./node_modules/tsx/dist/cli.mjs prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.10.0",
    "@prisma/client": "^6.17.0",
    "@radix-ui/react-slot": "^1.2.3",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.16",
    "lucide-react": "^0.468.0",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "nodemailer": "^6.9.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.25.76",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "^9.38.0",
    "eslint-config-next": "16.2.9",
    "postcss": "^8.5.6",
    "prisma": "^6.17.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  }
}
